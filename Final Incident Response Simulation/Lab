Subtask 3.3: Eradication and Recovery
Remove threats and restore normal operations.

# Create eradication and recovery script
cat > ~/incident-response-lab/scripts/eradication_recovery.sh << 'EOF'
#!/bin/bash

echo "=== ERADICATION AND RECOVERY PROCEDURES ==="

# Eradication phase
echo "Phase 1: ERADICATION"
echo "1. Removing malware and malicious files..."

# Remove quarantined files
sudo rm -rf /quarantine/*

# Clean temporary directories
sudo find /tmp -name "*.exe" -delete
sudo find /tmp -name "suspicious*" -delete

# Update and run security scans
sudo apt update
sudo apt install -y clamav clamav-daemon
sudo freshclam
sudo clamscan -r /home --infected --remove

echo "Malware removal completed"

# Patch vulnerabilities
echo "2. Patching vulnerabilities..."
sudo apt upgrade -y

# Harden web server configuration
if [ -f /etc/apache2/apache2.conf ]; then
    sudo sed -i 's/ServerTokens OS/ServerTokens Prod/' /etc/apache2/conf-available/security.conf
    sudo sed -i 's/ServerSignature On/ServerSignature Off/' /etc/apache2/conf-available/security.conf
    sudo systemctl restart apache2
fi

echo "System hardening completed"

# Recovery phase
echo "Phase 2: RECOVERY"
echo "1. Restoring services..."

# Restart security services
sudo systemctl restart wazuh-manager
sudo systemctl restart wazuh-agent
sudo systemctl restart suricata
sudo /opt/zeek/bin/zeekctl restart

# Verify service status
echo "Service status verification:"
sudo systemctl status wazuh-manager --no-pager -l
sudo systemctl status suricata --no-pager -l

echo "2. Implementing additional monitoring..."

# Enhanced monitoring rules
sudo tee -a /var/ossec/etc/ossec.conf << 'MONITORING_EOF'
<localfile>
  <log_format>syslog</log_format>
  <location>/var/log/auth.log</location>
</localfile>
<localfile>
  <log_format>apache</log_format>
  <location>/var/log/apache2/access.log</location>
</localfile>
MONITORING_EOF

sudo systemctl restart wazuh-manager

echo "Enhanced monitoring implemented"

echo "3. Backup and documentation..."

# Create system backup (simplified)
sudo tar -czf ~/incident-response-lab/evidence/system_backup_$(date +%Y%m%d).tar.gz /etc /var/log

echo "System backup created"

echo "=== ERADICATION AND RECOVERY COMPLETE ==="
EOF

