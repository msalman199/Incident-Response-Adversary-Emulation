#!/bin/bash

# Simple Nmap Results Analyzer

if [ $# -eq 0 ]; then
    echo "Usage: $0 <results_directory>"
    exit 1
fi

RESULTS_DIR=$1

echo "========================================="
echo "    NMAP RESULTS ANALYSIS"
echo "========================================="
echo ""

# Count total open ports
OPEN_PORTS=$(find "$RESULTS_DIR" -name "*.txt" -exec grep -h "open" {} \; | wc -l)
