cat > performance_test.py << 'EOF'
#!/usr/bin/env python3
import time
import subprocess
import statistics

def time_command(command, iterations=3):
    """Time a command execution multiple times"""
    times = []
    
    for i in range(iterations):
        start_time = time.time()
        try:
            result = subprocess.run(command, shell=True, capture_output=True, 
                                  text=True, timeout=60)
            end_time = time.time()
            
            if result.returncode == 0:
                times.append(end_time - start_time)
            else:
                print(f"Command failed on iteration {i+1}")
        except subprocess.TimeoutExpired:
            print(f"Command timed out on iteration {i+1}")
        except Exception as e:
            print(f"Error on iteration {i+1}: {e}")
    
    if times:
        avg_time = statistics.mean(times)
        return avg_time
    else:
        return None

def main():
    print("Performance Testing OSINT Tools")
    print("=" * 40)
    
    test_domain = "example.com"  # Use a safe test domain
    
    performance_tests = [
        (f"theharvester -d {test_domain} -l 10 -b google", "theHarvester"),
        (f"dnsrecon -d {test_domain} -t std", "DNSrecon"),
        (f"nslookup {test_domain}", "DNS Lookup")
    ]
    
    for command, tool_name in performance_tests:
        print(f"\nTesting {tool_name}...")
        avg_time = time_command(command)
        
        if avg_time:
            print(f"  Average execution time: {avg_time:.2f} seconds")
        else:
            print(f"  Failed to complete performance test")

if __name__ == "__main__":
    main()
EOF

