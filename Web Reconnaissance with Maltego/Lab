#!/usr/bin/env python3
import csv
import json
from datetime import datetime
import os

def generate_html_report(csv_file, output_file):
    """Generate HTML report from Maltego CSV export"""
    
    html_template = """
    <!DOCTYPE html>
    <html>
    <head>
        <title>Maltego Reconnaissance Report</title>
        <style>
            body { font-family: Arial, sans-serif; margin: 20px; }
            .header { background-color: #f0f0f0; padding: 20px; border-radius: 5px; }
            .section { margin: 20px 0; }
            table { border-collapse: collapse; width: 100%; }
            th, td { border: 1px solid #ddd; padding: 8px; text-align: left; }
            th { background-color: #f2f2f2; }
            .entity-type { font-weight: bold; color: #0066cc; }
        </style>
    </head>
    <body>
        <div class="header">
            <h1>Web Reconnaissance Report</h1>
            <p>Generated on: {timestamp}</p>
            <p>Tool: Maltego Community Edition</p>
        </div>
        
        <div class="section">
            <h2>Executive Summary</h2>
            <p>This report contains the results of web reconnaissance performed using Maltego 
               and integrated OSINT tools. The investigation mapped relationships between 
               domains, IP addresses, email addresses, and infrastructure components.</p>
        </div>
        
        <div class="section">
            <h2>Discovered Entities</h2>
            <table>
                <tr>
                    <th>Entity Type</th>
                    <th>Value</th>
                    <th>Additional Information</th>
                </tr>
                {table_rows}
            </table>
        </div>
        
        <div class="section">
            <h2>Key Findings</h2>
            <ul>
                <li>Total entities discovered: {total_entities}</li>
                <li>Unique domains identified: {domain_count}</li>
                <li>Email addresses found: {email_count}</li>
                <li>IP addresses mapped: {ip_count}</li>
            </ul>
        </div>
    </body>
    </html>
    """
    
    # Read CSV data
    entities = []
    entity_counts = {}
    
    try:
        with open(csv_file, 'r', newline='', encoding='utf-8') as f:
            reader = csv.DictReader(f)
            for row in reader:
                entities.append(row)
                entity_type = row.get('Entity Type', 'Unknown')
                entity_counts[entity_type] = entity_counts.get(entity_type, 0) + 1
    except FileNotFoundError:
        print(f"CSV file {csv_file} not found. Please export data from Maltego first.")
        return
    
    # Generate table rows
    table_rows = ""
    for entity in entities:
        entity_type = entity.get('Entity Type', 'Unknown')
        value = entity.get('Entity Value', 'Unknown')
        additional = entity.get('Additional Fields', '')
        
        table_rows += f"""
        <tr>
            <td class="entity-type">{entity_type}</td>
            <td>{value}</td>
            <td>{additional}</td>
        </tr>
        """
    
    # Calculate statistics
    total_entities = len(entities)
    domain_count = entity_counts.get('maltego.Domain', 0)
    email_count = entity_counts.get('maltego.EmailAddress', 0)
    ip_count = entity_counts.get('maltego.IPv4Address', 0)
    
    # Generate final HTML
    html_content = html_template.format(
        timestamp=datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
        table_rows=table_rows,
        total_entities=total_entities,
        domain_count=domain_count,
        email_count=email_count,
        ip_count=ip_count
    )
    
    # Write HTML file
    with open(output_file, 'w', encoding='utf-8') as f:
        f.write(html_content)
    
    print(f"Report generated: {output_file}")

def main():
    csv_file = "maltego_export.csv"  # Default CSV export filename
    output_file = "reconnaissance_report.html"
    
    if os.path.exists(csv_file):
        generate_html_report(csv_file, output_file)
    else:
        print(f"Please export your Maltego graph to CSV as '{csv_file}' first.")
        print("In Maltego: File > Export > Export to CSV")

if __name__ == "__main__":
    main()
EOF

