#!/usr/bin/env python3
import subprocess
import ipaddress
import json

def analyze_network_range(ip_address):
    try:
        # Get network information using whois
        result = subprocess.run(['whois', ip_address], 
                              capture_output=True, text=True)
        
        # Extract network range
        lines = result.stdout.split('\n')
        network_info = {}
        
        for line in lines:
            if 'NetRange:' in line or 'inetnum:' in line:
                network_info['range'] = line.split(':')[1].strip()
            elif 'Organization:' in line or 'org-name:' in line:
                network_info['org'] = line.split(':')[1].strip()
            elif 'Country:' in line:
                network_info['country'] = line.split(':')[1].strip()
        
        return network_info
    except Exception as e:
        print(f"Error analyzing {ip_address}: {e}")
        return {}

def main():
    # Example IP addresses to analyze
    ips = ['8.8.8.8', '1.1.1.1']  # Replace with discovered IPs
    
    for ip in ips:
        print(f"\nAnalyzing {ip}:")
        info = analyze_network_range(ip)
        for key, value in info.items():
            print(f"  {key}: {value}")

if __name__ == "__main__":
    main()
EOF

