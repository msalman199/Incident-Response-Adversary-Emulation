#!/usr/bin/env python3
"""
Simple visualization script for theHarvester results
"""

import matplotlib.pyplot as plt
import json
import sys
from collections import Counter

def create_simple_charts(json_file):
    """Create simple charts from JSON data"""
    try:
        with open(json_file, 'r') as f:
            data = json.load(f)
        
        # Email domain distribution
        emails = data['findings']['emails']
        email_domains = [email.split('@')[1] for email in emails if '@' in email]
        domain_counts = Counter(email_domains)
        
        # Print text-based chart
        print("Email Domain Distribution:")
        print("-" * 30)
        for domain, count in domain_counts.most_common(10):
            bar = "█" * count
            print(f"{domain:20} {bar} ({count})")
        
        # Subdomain analysis
        subdomains = data['findings']['subdomains']
        print(f"\nTotal Subdomains Found: {len(subdomains)}")
        print("Top Subdomains:")
        print("-" * 20)
        for i, subdomain in enumerate(subdomains[:10], 1):
            print(f"{i:2}. {subdomain}")
        
    except Exception as e:
        print(f"Error processing file: {e}")

if __name__ == "__main__":
    if len(sys.argv) != 2:
        print("Usage: python3 visualize_results.py <json_report_file>")
        sys.exit(1)
    
    create_simple_charts(sys.argv[1])
