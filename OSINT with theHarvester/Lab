Modify your scripts to include respectful rate limiting:

#!/usr/bin/env python3
"""
Rate-limited theHarvester wrapper
"""

import time
import subprocess
import sys

def rate_limited_harvest(domain, sources, delay=5):
    """Run theHarvester with rate limiting between requests"""
    source_list = sources.split(',')
    
    for source in source_list:
        print(f"Scanning {domain} using {source}...")
        
        cmd = [
            "python3", "theHarvester.py",
            "-d", domain,
            "-l", "50",  # Reduced limit for respectful scanning
            "-b", source,
            "-f", f"{domain}_{source}"
        ]
        
        try:
            subprocess.run(cmd, cwd=".")
            print(f"Completed scan with {source}")
            
            # Rate limiting delay
            if source != source_list[-1]:  # Don't delay after last source
                print(f"Waiting {delay} seconds before next scan...")
                time.sleep(delay)
                
        except Exception as e:
            print(f"Error with {source}: {e}")

if __name__ == "__main__":
    if len(sys.argv) != 3:
        print("Usage: python3 rate_limited_harvest.py <domain> <sources>")
        print("Example: python3 rate_limited_harvest.py example.com google,bing")
        sys.exit(1)
    
    domain = sys.argv[1]
    sources = sys.argv[2]
    
    rate_limited_harvest(domain, sources)
