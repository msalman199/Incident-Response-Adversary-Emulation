#!/usr/bin/env python3
"""
Advanced theHarvester Data Processor
Processes and analyzes OSINT data with enhanced reporting
"""

import subprocess
import json
import csv
import re
import datetime
import os
from collections import defaultdict

class AdvancedHarvesterProcessor:
    def __init__(self, domain):
        self.domain = domain
        self.timestamp = datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
        self.results = {
            'emails': [],
            'subdomains': [],
            'hosts': [],
            'urls': []
        }
    
    def extract_emails(self, text):
        """Extract email addresses from text"""
        email_pattern = r'\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Z|a-z]{2,}\b'
        emails = re.findall(email_pattern, text)
        return list(set(emails))  # Remove duplicates
    
    def extract_subdomains(self, text):
        """Extract subdomains from text"""
        subdomain_pattern = rf'\b[\w.-]*\.{re.escape(self.domain)}\b'
        subdomains = re.findall(subdomain_pattern, text, re.IGNORECASE)
        return list(set(subdomains))
    
    def process_harvester_output(self, output_text):
        """Process theHarvester output and categorize findings"""
        self.results['emails'] = self.extract_emails(output_text)
        self.results['subdomains'] = self.extract_subdomains(output_text)
        
        # Additional processing for hosts and URLs
        lines = output_text.split('\n')
        for line in lines:
            if 'http' in line.lower():
                self.results['urls'].append(line.strip())
    
    def generate_csv_report(self):
        """Generate CSV reports for each data type"""
        reports = []
        
        # Email report
        email_file = f"emails_{self.domain}_{self.timestamp}.csv"
        with open(email_file, 'w', newline='') as csvfile:
            writer = csv.writer(csvfile)
            writer.writerow(['Email', 'Domain'])
            for email in self.results['emails']:
                domain_part = email.split('@')[1] if '@' in email else ''
                writer.writerow([email, domain_part])
        reports.append(email_file)
        
        # Subdomain report
        subdomain_file = f"subdomains_{self.domain}_{self.timestamp}.csv"
        with open(subdomain_file, 'w', newline='') as csvfile:
            writer = csv.writer(csvfile)
            writer.writerow(['Subdomain', 'Root Domain'])
            for subdomain in self.results['subdomains']:
                writer.writerow([subdomain, self.domain])
        reports.append(subdomain_file)
        
        return reports
    
    def generate_statistics(self):
        """Generate statistics about the findings"""
        stats = {
            'total_emails': len(self.results['emails']),
            'total_subdomains': len(self.results['subdomains']),
            'total_urls': len(self.results['urls']),
            'unique_email_domains': len(set([email.split('@')[1] for email in self.results['emails'] if '@' in email]))
        }
        return stats
    
    def create_comprehensive_report(self):
        """Create a comprehensive JSON report"""
        report_data = {
            'scan_info': {
                'target_domain': self.domain,
                'scan_timestamp': self.timestamp,
                'scan_date': datetime.datetime.now().isoformat()
            },
            'statistics': self.generate_statistics(),
            'findings': self.results
        }
        
        report_file = f"comprehensive_report_{self.domain}_{self.timestamp}.json"
        with open(report_file, 'w') as f:
            json.dump(report_data, f, indent=2)
        
        return report_file

def run_automated_scan(domain):
    """Run automated theHarvester scan with multiple sources"""
    processor = AdvancedHarvesterProcessor(domain)
    
    # Define source combinations
    source_sets = [
        "google,bing",
        "dnsdumpster,crtsh",
        "virustotal"
    ]
    
    all_output = ""
    
    for sources in source_sets:
        print(f"Running scan with sources: {sources}")
        cmd = [
            "python3", "theHarvester.py",
            "-d", domain,
            "-l", "200",
            "-b", sources
        ]
        
        try:
            result = subprocess.run(cmd, capture_output=True, text=True, cwd=".")
            if result.returncode == 0:
                all_output += result.stdout + "\n"
                print(f"Completed scan with {sources}")
            else:
                print(f"Error with {sources}: {result.stderr}")
        except Exception as e:
            print(f"Exception with {sources}: {str(e)}")
    
    # Process all collected output
    processor.process_harvester_output(all_output)
    
    # Generate reports
    csv_reports = processor.generate_csv_report()
    json_report = processor.create_comprehensive_report()
    
    print(f"\nScan completed for {domain}")
    print(f"Generated reports:")
    for report in csv_reports + [json_report]:
        print(f"  - {report}")
    
    return processor.results

if __name__ == "__main__":
    import sys
    if len(sys.argv) != 2:
        print("Usage: python3 advanced_processor.py <domain>")
        sys.exit(1)
    
    domain = sys.argv[1]
    results = run_automated_scan(domain)
    
    # Display summary
    print(f"\nSummary for {domain}:")
    print(f"Emails found: {len(results['emails'])}")
    print(f"Subdomains found: {len(results['subdomains'])}")
    print(f"URLs found: {len(results['urls'])}")
