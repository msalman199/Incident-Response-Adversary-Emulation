Troubleshooting Common Issues
Issue 1: OpenCL Device Not Found
# Check OpenCL installation
clinfo

# If not installed, install OpenCL
sudo apt install clinfo ocl-icd-opencl-dev

# For NVIDIA GPUs
sudo apt install nvidia-opencl-dev

# For AMD GPUs
sudo apt install mesa-opencl-icd
Issue 2: Hashcat Not Recognizing GPU
# Check GPU status
lspci | grep -i vga

# Verify drivers
nvidia-smi  # For NVIDIA
rocm-smi    # For AMD

# Reinstall drivers if needed
sudo apt purge nvidia-* && sudo apt autoremove
sudo apt install nvidia-driver-470
Issue 3: Performance Issues
# Check system resources
htop

# Verify thermal throttling
sensors

# Optimize workload profile
hashcat --help | grep workload-profile
