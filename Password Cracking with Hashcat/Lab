Task 1: Environment Setup and Hash Preparation
Subtask 1.1: Install Hashcat and Dependencies
First, we need to install Hashcat and verify our system capabilities.

# Update system packages
sudo apt update && sudo apt upgrade -y

# Install Hashcat and required dependencies
sudo apt install hashcat opencl-headers ocl-icd-opencl-dev -y

# Install additional GPU drivers if needed (NVIDIA)
sudo apt install nvidia-driver-470 nvidia-opencl-dev -y

# Verify Hashcat installation
hashcat --version

# Check available OpenCL devices
hashcat -I
Subtask 1.2: Create Sample Hash Files
We'll create various hash types to practice different cracking techniques.

# Create a working directory
mkdir ~/hashcat_lab
cd ~/hashcat_lab

# Create MD5 hashes for testing
echo -n "password123" | md5sum | cut -d' ' -f1 > md5_hashes.txt
echo -n "admin2023" | md5sum | cut -d' ' -f1 >> md5_hashes.txt
echo -n "welcome" | md5sum | cut -d' ' -f1 >> md5_hashes.txt
echo -n "qwerty" | md5sum | cut -d' ' -f1 >> md5_hashes.txt

# Create SHA-256 hashes
echo -n "password123" | sha256sum | cut -d' ' -f1 > sha256_hashes.txt
echo -n "admin2023" | sha256sum | cut -d' ' -f1 >> sha256_hashes.txt
echo -n "welcome" | sha256sum | cut -d' ' -f1 >> sha256_hashes.txt
echo -n "qwerty" | sha256sum | cut -d' ' -f1 >> sha256_hashes.txt

# Display created hashes
echo "MD5 Hashes:"
cat md5_hashes.txt
echo -e "\nSHA-256 Hashes:"
cat sha256_hashes.txt
Subtask 1.3: Download and Prepare Wordlists
# Create wordlist directory
mkdir wordlists
cd wordlists

# Download popular wordlists
wget https://github.com/danielmiessler/SecLists/raw/master/Passwords/Common-Credentials/10-million-password-list-top-1000000.txt -O top1m.txt

# Create a custom small wordlist for testing
cat > custom_wordlist.txt << 'EOF'
password
123456
password123
admin
admin2023
welcome
qwerty
letmein
monkey
dragon
EOF

# Create a numeric wordlist
seq 1000 9999 > numeric.txt

# Return to main directory
cd ~/hashcat_lab
Task 2: Basic Password Cracking Techniques
Subtask 2.1: Dictionary Attack on MD5 Hashes
Let's start with a basic dictionary attack using our custom wordlist.

# Perform dictionary attack on MD5 hashes
hashcat -m 0 -a 0 md5_hashes.txt wordlists/custom_wordlist.txt

# Check results
hashcat -m 0 md5_hashes.txt --show

# Save results to file
hashcat -m 0 md5_hashes.txt --show > md5_cracked.txt
echo "Cracked MD5 passwords:"
cat md5_cracked.txt
Subtask 2.2: Dictionary Attack on SHA-256 Hashes
# Perform dictionary attack on SHA-256 hashes
hashcat -m 1400 -a 0 sha256_hashes.txt wordlists/custom_wordlist.txt

# Check and save results
hashcat -m 1400 sha256_hashes.txt --show > sha256_cracked.txt
echo "Cracked SHA-256 passwords:"
cat sha256_cracked.txt
Subtask 2.3: Performance Analysis - CPU vs GPU
# Create performance test script
cat > performance_test.sh << 'EOF'
#!/bin/bash

echo "=== Performance Comparison Test ==="
echo "Testing MD5 hash cracking performance"
echo

# Test with CPU only (OpenCL device 1, usually CPU)
echo "CPU-only test:"
time hashcat -m 0 -a 0 -d 1 --quiet md5_hashes.txt wordlists/top1m.txt 2>/dev/null

echo
echo "GPU-accelerated test:"
# Test with GPU (OpenCL device 2, usually GPU)
time hashcat -m 0 -a 0 -d 2 --quiet md5_hashes.txt wordlists/top1m.txt 2>/dev/null

echo
echo "Performance test completed"
EOF

# Make script executable and run
chmod +x performance_test.sh
./performance_test.sh
Task 3: Advanced Cracking Techniques
Subtask 3.1: Brute Force Attack
# Create simple hashes for brute force testing
echo -n "abc" | md5sum | cut -d' ' -f1 > simple_md5.txt
echo -n "123" | md5sum | cut -d' ' -f1 >> simple_md5.txt

# Brute force attack - 3 character lowercase
hashcat -m 0 -a 3 simple_md5.txt ?l?l?l

# Brute force attack - 3 character digits
hashcat -m 0 -a 3 simple_md5.txt ?d?d?d

# Show cracked results
hashcat -m 0 simple_md5.txt --show
Subtask 3.2: Rule-Based Attack
# Create a rules file for common password variations
cat > custom.rule << 'EOF'
:
c
u
$1
$2
$3
$!
$@
^1
^2
^3
EOF

# Apply rules to dictionary attack
hashcat -m 0 -a 0 md5_hashes.txt wordlists/custom_wordlist.txt -r custom.rule

# Check results
hashcat -m 0 md5_hashes.txt --show
Subtask 3.3: Combination Attack
# Create two small wordlists for combination
echo -e "pass\nadmin\nuser" > left.txt
echo -e "word\n123\n2023" > right.txt

# Create combination hashes to test
echo -n "password" | md5sum | cut -d' ' -f1 > combo_test.txt
echo -n "admin123" | md5sum | cut -d' ' -f1 >> combo_test.txt
echo -n "user2023" | md5sum | cut -d' ' -f1 >> combo_test.txt

# Perform combination attack
hashcat -m 0 -a 1 combo_test.txt left.txt right.txt

# Show results
hashcat -m 0 combo_test.txt --show
