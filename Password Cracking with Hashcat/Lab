Subtask 4.2: Performance Optimization
# Create optimized cracking script
cat > optimized_crack.sh << 'EOF'
#!/bin/bash

HASH_FILE="$1"
WORDLIST="$2"
HASH_MODE="$3"

if [ $# -ne 3 ]; then
    echo "Usage: $0 <hash_file> <wordlist> <hash_mode>"
    echo "Example: $0 md5_hashes.txt wordlists/top1m.txt 0"
    exit 1
fi

echo "=== Optimized Hashcat Cracking ==="
echo "Hash file: $HASH_FILE"
echo "Wordlist: $WORDLIST"
echo "Hash mode: $HASH_MODE"
echo

# Use optimized settings
hashcat -m "$HASH_MODE" -a 0 "$HASH_FILE" "$WORDLIST" \
    --optimized-kernel-enable \
    --workload-profile 3 \
    --status \
    --status-timer 10

echo -e "\nCracking completed. Results:"
hashcat -m "$HASH_MODE" "$HASH_FILE" --show
EOF

# Make executable
chmod +x optimized_crack.sh

# Test with our MD5 hashes
./optimized_crack.sh md5_hashes.txt wordlists/top1m.txt 0
Task 5: Analysis and Reporting
Subtask 5.1: Create Comprehensive Report
# Create analysis script
cat > analysis_report.sh << 'EOF'
#!/bin/bash

echo "=== Password Cracking Analysis Report ==="
echo "Generated on: $(date)"
echo "Analyst: $(whoami)"
echo

echo "## Hash Analysis Summary"
echo

echo "### MD5 Hashes Analyzed:"
wc -l md5_hashes.txt
echo "Cracked:"
if [ -f md5_cracked.txt ]; then
    wc -l md5_cracked.txt
    echo "Success Rate: $(echo "scale=2; $(wc -l < md5_cracked.txt) * 100 / $(wc -l < md5_hashes.txt)" | bc)%"
else
    echo "0"
fi

echo
echo "### SHA-256 Hashes Analyzed:"
wc -l sha256_hashes.txt
echo "Cracked:"
if [ -f sha256_cracked.txt ]; then
    wc -l sha256_cracked.txt
    echo "Success Rate: $(echo "scale=2; $(wc -l < sha256_cracked.txt) * 100 / $(wc -l < sha256_hashes.txt)" | bc)%"
else
    echo "0"
fi

echo
echo "## Cracked Passwords Analysis"
echo

if [ -f md5_cracked.txt ]; then
    echo "### MD5 Cracked Passwords:"
    cat md5_cracked.txt | cut -d':' -f2 | sort | uniq -c | sort -nr
fi

if [ -f sha256_cracked.txt ]; then
    echo "### SHA-256 Cracked Passwords:"
    cat sha256_cracked.txt | cut -d':' -f2 | sort | uniq -c | sort -nr
fi

echo
echo "## Security Recommendations"
echo "1. Avoid common passwords found in wordlists"
echo "2. Use complex passwords with mixed character sets"
echo "3. Implement proper password policies"
echo "4. Consider using stronger hashing algorithms"
echo "5. Implement salt for password hashing"
EOF

# Generate report
chmod +x analysis_report.sh
./analysis_report.sh > final_report.txt

# Display report
cat final_report.txt
