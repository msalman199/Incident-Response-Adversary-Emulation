Step 2: Configure Fail2Ban
Set up automated intrusion prevention:

# Install Fail2Ban
sudo apt install -y fail2ban

# Create custom configuration
sudo tee /etc/fail2ban/jail.local > /dev/null << 'EOF'
[DEFAULT]
bantime = 600
findtime = 300
maxretry = 3

[vsftpd]
enabled = true
port = ftp
logpath = /var/log/vsftpd.log
maxretry = 3

[apache-auth]
enabled = true
port = http,https
logpath = /var/log/apache2/error.log
maxretry = 3
EOF

# Start Fail2Ban
sudo systemctl start fail2ban
sudo systemctl enable fail2ban

# Check status
sudo fail2ban-client status
Step 3: Test Defense Effectiveness
Verify that defenses work:

# Trigger Fail2Ban by multiple failed attempts
for i in {1..5}; do
    hydra -l baduser -p badpass 127.0.0.1 ftp
    sleep 1
done

# Check if IP was banned
sudo fail2ban-client status vsftpd

# Unban yourself for continued testing
sudo fail2ban-client set vsftpd unbanip 127.0.0.1
