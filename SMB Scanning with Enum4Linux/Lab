#!/usr/bin/env python3

import os
import re
import sys
from datetime import datetime

def analyze_users(file_path):
    """Analyze user enumeration results"""
    users = []
    try:
        with open(file_path, 'r') as f:
            content = f.read()
            # Extract usernames using regex
            user_matches = re.findall(r'user:\[([^\]]+)\]', content)
            users.extend(user_matches)
            
            # Also look for RID cycling results
            rid_matches = re.findall(r'S-1-5-21-\d+-\d+-\d+-(\d+)\s+(\w+)', content)
            for rid, username in rid_matches:
                if username not in users:
                    users.append(username)
    except FileNotFoundError:
        print(f"File not found: {file_path}")
    
    return users

def analyze_shares(file_path):
    """Analyze share enumeration results"""
    shares = []
    try:
        with open(file_path, 'r') as f:
            content = f.read()
            # Extract share names
            share_matches = re.findall(r'Sharename\s+Type\s+Comment\s*\n\s*-+\s*\n(.*?)(?=\n\n|\Z)', content, re.DOTALL)
