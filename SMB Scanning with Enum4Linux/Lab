Task 2: Python Scripts for Automated SMB Enumeration
Subtask 2.1: Creating a Basic SMB Scanner
Let's create a Python script that automates SMB enumeration for multiple targets:

#!/usr/bin/env python3
"""
SMB Network Scanner
Automates SMB enumeration across multiple targets
"""

import subprocess
import threading
import argparse
import ipaddress
import os
import time
from concurrent.futures import ThreadPoolExecutor, as_completed

class SMBScanner:
    def __init__(self, max_threads=10):
        self.max_threads = max_threads
        self.results = {}
        self.lock = threading.Lock()
    
    def check_smb_port(self, target, port=445, timeout=3):
        """Check if SMB port is open"""
        try:
            import socket
            sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            sock.settimeout(timeout)
            result = sock.connect_ex((str(target), port))
            sock.close()
            return result == 0
        except Exception:
            return False
    
    def run_enum4linux(self, target):
        """Run enum4linux against a target"""
        try:
            # Create output directory
            output_dir = f"smb_scan_{target}_{int(time.time())}"
            os.makedirs(output_dir, exist_ok=True)
            
            # Run enum4linux
            cmd = ['enum4linux', '-a', str(target)]
            result = subprocess.run(cmd, capture_output=True, text=True, timeout=300)
            
            # Save results
            output_file = os.path.join(output_dir, 'enum4linux_output.txt')
            with open(output_file, 'w') as f:
                f.write(f"Target: {target}\n")
                f.write(f"Command: {' '.join(cmd)}\n")
                f.write("=" * 60 + "\n")
                f.write(result.stdout)
                if result.stderr:
                    f.write("\nERRORS:\n")
                    f.write(result.stderr)
            
            return {
                'target': str(target),
                'success': result.returncode == 0,
                'output_file': output_file,
                'stdout': result.stdout,
                'stderr': result.stderr
            }
            
        except subprocess.TimeoutExpired:
            return {
                'target': str(target),
                'success': False,
                'error': 'Timeout expired',
                'output_file': None
            }
        except Exception as e:
            return {
                'target': str(target),
                'success': False,
                'error': str(e),
                'output_file': None
            }
    
    def scan_target(self, target):
        """Scan a single target"""
        print(f"[+] Scanning {target}...")
        
        # Check if SMB port is open
        if not self.check_smb_port(target):
            print(f"[-] SMB port 445 closed on {target}")
            return {
                'target': str(target),
                'success': False,
                'error': 'SMB port closed'
            }
        
        print(f"[+] SMB port open on {target}, running enumeration...")
        result = self.run_enum4linux(target)
        
        with self.lock:
            self.results[str(target)] = result
        
        if result['success']:
            print(f"[+] Enumeration completed for {target}")
        else:
            print(f"[-] Enumeration failed for {target}: {result.get('error', 'Unknown error')}")
        
        return result
    
    def scan_network(self, targets):
        """Scan multiple targets concurrently"""
        print(f"[+] Starting SMB enumeration scan of {len(targets)} targets")
        print(f"[+] Using {self.max_threads} threads")
        
        with ThreadPoolExecutor(max_workers=self.max_threads) as executor:
            future_to_target = {executor.submit(self.scan_target, target): target for target in targets}
            
            for future in as_completed(future_to_target):
                target = future_to_target[future]
                try:
                    result = future.result()
                except Exception as exc:
                    print(f"[-] {target} generated an exception: {exc}")
    
    def generate_report(self, output_file='smb_scan_report.txt'):
        """Generate a summary report"""
        successful_scans = [r for r in self.results.values() if r['success']]
        failed_scans = [r for r in self.results.values() if not r['success']]
        
        with open(output_file, 'w') as f:
            f.write("SMB ENUMERATION SCAN REPORT\n")
            f.write("=" * 50 + "\n")
            f.write(f"Scan Date: {time.strftime('%Y-%m-%d %H:%M:%S')}\n")
            f.write(f"Total Targets: {len(self.results)}\n")
            f.write(f"Successful Scans: {len(successful_scans)}\n")
            f.write(f"Failed Scans: {len(failed_scans)}\n\n")
            
            if successful_scans:
                f.write("SUCCESSFUL SCANS:\n")
                f.write("-" * 20 + "\n")
                for result in successful_scans:
                    f.write(f"Target: {result['target']}\n")
                    f.write(f"Output File: {result['output_file']}\n\n")
            
            if failed_scans:
                f.write("FAILED SCANS:\n")
                f.write("-" * 15 + "\n")
                for result in failed_scans:
                    f.write(f"Target: {result['target']}\n")
                    f.write(f"Error: {result.get('error', 'Unknown')}\n\n")
        
        print(f"[+] Report saved to {output_file}")

def parse_targets(target_input):
    """Parse target input (single IP, CIDR, or file)"""
    targets = []
    
    if os.path.isfile(target_input):
        # Read targets from file
        with open(target_input, 'r') as f:
            for line in f:
                line = line.strip()
                if line and not line.startswith('#'):
                    targets.append(line)
    else:
        try:
            # Try to parse as network
            network = ipaddress.ip_network(target_input, strict=False)
            targets = [str(ip) for ip in network.hosts()]
        except ValueError:
            # Single IP
            targets = [target_input]
    
    return targets

def main():
    parser = argparse.ArgumentParser(description='Automated SMB Enumeration Scanner')
    parser.add_argument('targets', help='Target IP, CIDR network, or file containing targets')
    parser.add_argument('-t', '--threads', type=int, default=10, help='Number of threads (default: 10)')
    parser.add_argument('-o', '--output', default='smb_scan_report.txt', help='Output report file')
    
    args = parser.parse_args()
    
    # Parse targets
    targets = parse_targets(args.targets)
    
    if not targets:
        print("[-] No valid targets found")
        return
    
    print(f"[+] Parsed {len(targets)} targets")
    
    # Create scanner and run scan
    scanner = SMBScanner(max_threads=args.threads)
    scanner.scan_network(targets)
    
    # Generate report
    scanner.generate_report(args.output)
    
    print("[+] Scan completed!")

if __name__ == "__main__":
    main()
